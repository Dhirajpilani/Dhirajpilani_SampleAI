# --- Recipient ---
RECIPIENT_EMAIL=your_email@example.com

# --- SMTP (Gmail/Outlook) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_app_password
SMTP_SENDER=your_sender@example.com

# --- APIs ---
# SerpAPI key used for LinkedIn/Indeed/Glassdoor discovery through Google Jobs engine
SERPAPI_API_KEY=your_serpapi_key

# --- Optional runtime tuning ---
JOB_KEYWORDS=R2R,Record to Report,Finance Transformation,BlackLine,Account Reconciliation,Senior Analyst,Manager
REMOTE_ONLY=false
MAX_TOP_JOBS=10
DB_PATH=jobs.db
LOG_FILE=job_alert.log
REQUEST_TIMEOUT_SECONDS=20
RETRIES=3
BACKOFF_SECONDS=2
